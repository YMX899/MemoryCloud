APP_ENV=development
PUBLIC_SITE_ORIGIN=http://127.0.0.1:8000
SECRET_KEY=change-me-before-production

DATA_ROOT=.memorycloud-data
DATABASE_PATH=.memorycloud-data/platform.sqlite3
STORAGE_DIR=.memorycloud-data/archives
LLM_PROVIDER_CONFIG=.memorycloud-data/llm_provider.json

MAX_UPLOAD_BYTES=15728640
POW_DIFFICULTY=4

SMS_DRY_RUN=true
SMS_API_BASE=
FX_AI_API_KEY=

EMAIL_DRY_RUN=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
SMTP_SSL=false
